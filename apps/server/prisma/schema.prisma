generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Galaxy {
  id        String   @id @default(cuid())
  name      String   @unique
  index     Int      @default(0)
  systems   System[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model System {
  id        String   @id @default(cuid())
  index     Int
  galaxyId  String
  galaxy    Galaxy   @relation(fields: [galaxyId], references: [id])
  planets   Planet[]
  star      Star?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([galaxyId, index])
}

model Star {
  id           String   @id @default(cuid())
  temperature  Int      // Kelvin
  energyOutput Float    // kW
  systemId     String   @unique
  system       System   @relation(fields: [systemId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Planet {
  id          String    @id @default(cuid())
  name        String
  slot        Int
  systemId    String
  system      System    @relation(fields: [systemId], references: [id])
  ownerId     String?
  owner       Player?   @relation(fields: [ownerId], references: [id])
  iron        Float     @default(500)
  silver      Float     @default(250)
  ember       Float     @default(0)
  h2          Float     @default(0)
  energy      Float     @default(0)
  lastSeen    DateTime  @default(now()) // Last time player viewed this planet (for offline production)
  fieldsUsed  Int       @default(0)
  fieldsMax   Int       @default(163)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  buildings   Building[]
  shipyards   Shipyard[]
  planetShips PlanetShip[]
  originFleets Fleet[]  @relation("OriginPlanet")
  targetFleets Fleet[]  @relation("TargetPlanet")
  combatReports CombatReport[]

  @@unique([systemId, slot])
}

model Player {
  id        String    @id @default(cuid())
  name      String    @unique
  apiKey    String?   @unique
  isBot     Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  planets         Planet[]
  fleets          Fleet[]
  research        Research[]
  attackerReports CombatReport[] @relation("AttackerReports")
  defenderReports CombatReport[] @relation("DefenderReports")
}

model Building {
  id              String        @id @default(cuid())
  planetId        String
  planet          Planet        @relation(fields: [planetId], references: [id])
  type            BuildingType
  level           Int           @default(0)
  isUpgrading     Boolean       @default(false)
  upgradeFinishAt DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  constructionQueue ConstructionQueue[]

  @@unique([planetId, type])
}

model ConstructionQueue {
  id              String    @id @default(cuid())
  buildingId      String
  building        Building  @relation(fields: [buildingId], references: [id])
  targetLevel     Int
  upgradeFinishAt DateTime
  createdAt       DateTime  @default(now())
}

model Fleet {
  id              String        @id @default(cuid())
  ownerId         String
  owner           Player        @relation(fields: [ownerId], references: [id])
  originPlanetId  String
  originPlanet    Planet        @relation("OriginPlanet", fields: [originPlanetId], references: [id])
  targetPlanetId  String?
  targetPlanet    Planet?       @relation("TargetPlanet", fields: [targetPlanetId], references: [id])
  mission         FleetMission
  iron            Float         @default(0)
  silver          Float         @default(0)
  ember           Float         @default(0)
  h2              Float         @default(0)
  energy          Float         @default(0)
  launchedAt      DateTime      @default(now())
  arrivesAt       DateTime
  returnsAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  ships           FleetShip[]
}

model FleetShip {
  id       String  @id @default(cuid())
  fleetId  String
  fleet    Fleet   @relation(fields: [fleetId], references: [id], onDelete: Cascade)
  type     ShipType
  count    Int
}

model Research {
  id               String       @id @default(cuid())
  playerId         String
  player           Player       @relation(fields: [playerId], references: [id])
  type             ResearchType
  level            Int          @default(0)
  isResearching    Boolean      @default(false)
  researchFinishAt DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@unique([playerId, type])
}

model Shipyard {
  id            String    @id @default(cuid())
  planetId      String
  planet        Planet    @relation(fields: [planetId], references: [id])
  shipType      ShipType
  count         Int       @default(1)
  isBuilding    Boolean   @default(false)
  buildFinishAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([planetId, shipType])
}

model PlanetShip {
  planetId   String
  shipType  ShipType
  count     Int       @default(0)
  planet    Planet    @relation(fields: [planetId], references: [id])
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([planetId, shipType])
}

model CombatReport {
  id              String   @id @default(cuid())
  attackerId      String
  attacker        Player   @relation("AttackerReports", fields: [attackerId], references: [id])
  defenderId      String
  defender        Player   @relation("DefenderReports", fields: [defenderId], references: [id])
  planetId        String
  planet          Planet   @relation(fields: [planetId], references: [id])
  mission         FleetMission
  winner          String   // 'ATTACKER' | 'DEFENDER' | 'DRAW'
  attackerShips   Json     // { sent: [...], lost: [...], remaining: [...] }
  defenderShips   Json     // { sent: [...], lost: [...], remaining: [...] }
  loot            Json?    // { iron, silver, ember, h2, energy } or null if defender won
  fuelCost        Float    // Total round-trip H2 cost for the attacking fleet
  createdAt       DateTime @default(now())
}

enum BuildingType {
  zentrale
  iron_mine        // Iron mine
  silver_mine      // Silver mine
  uderon_raffinery // Uderon refinery
  h2_refinery      // H2 refinery
  fusion_plant     // Fusion power plant
  research_center  // Research center
  shipyard          // Shipyard
  space_station     // Space station
  anti_spy          // Anti-spy shield
  planetary_shield  // Planetary shield generator
  dummy_building    // Dummy building (for fastbuild)
}

enum ShipType {
  fly
  bumblebee
  corvette
  light_cruiser
  heavy_cruiser
  battleship
  battleship_nexus
  battleship_phoenix
  carrier_titan
  colonizer
  invasion_unit
  ember_bomb
}

enum FleetMission {
  attack
  transport
  deployment
  colonize
  harvest
  espionage
  invasion
  destroy
}

enum ResearchType {
  iron_mining      // Iron mining +5% per level
  silver_mining    // Silver mining +5% per level
  ember_extraction // Ember extraction +5% per level
  h2_refining      // H2 refining +5% per level
  energy_efficiency // Energy efficiency +5% per level
  laser_technology
  ion_technology
  hyperspace_technology
  plasma_technology
  combustion_drive
  impulse_drive
  hyperspace_drive
  espionage_technology
  computer_technology
  astrophysics
  intergalactic_research_network
  graviton_technology
  shield_technology
  armour_technology
  weapons_technology
}